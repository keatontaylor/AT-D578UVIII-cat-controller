# /etc/nginx/sites-available/anytone — HTTPS reverse proxy for the controller.
# The app is SUBPATH-NATIVE at /anytone-v2/ — proxy WITHOUT stripping the prefix.
map $http_upgrade $connection_upgrade {
  default upgrade;
  ''      close;
}
server {
  server_name _;
  listen 80;
  location / { return 301 https://$host$request_uri; }
}
server {
  server_name _;
  listen 443 ssl;
  ssl_certificate     /etc/nginx/ssl/anytone.crt;
  ssl_certificate_key /etc/nginx/ssl/anytone.key;

  proxy_http_version 1.1;
  proxy_set_header Host $host;
  proxy_set_header X-Real-IP $remote_addr;
  proxy_set_header X-Forwarded-Proto $scheme;
  proxy_set_header Upgrade $http_upgrade;
  proxy_set_header Connection $connection_upgrade;
  proxy_read_timeout 1h;
  proxy_send_timeout 1h;

  location = /anytone-v2 { return 302 /anytone-v2/; }
  location /anytone-v2/ { proxy_pass http://127.0.0.1:8080; }
  location = / { return 302 /anytone-v2/; }
}
