# Example nginx reverse proxy for the AnyTone controller.
# OPTIONAL — the app runs fine without nginx (open http://<host>:3030/ directly).
# Use a reverse proxy to add TLS and/or expose the UI on a public hostname.
#
# This is a TEMPLATE: replace every <PLACEHOLDER>. The key requirement is that
# Server-Sent Events (/api/events) and the audio stream are NOT buffered.
#
# Install (Debian/Ubuntu style):
#   sudo cp anytone.conf.example /etc/nginx/sites-available/anytone.conf
#   sudo edit placeholders; sudo ln -s ../sites-available/anytone.conf /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx

server {
    listen 443 ssl;
    server_name <YOUR_HOSTNAME>;

    # TLS — point these at your certificate (e.g. from certbot/Let's Encrypt):
    ssl_certificate     <PATH_TO_FULLCHAIN.pem>;
    ssl_certificate_key <PATH_TO_PRIVKEY.pem>;

    # --- Option A (recommended): serve the UI at the site root ---------------
    # The app defaults to baseURL "/", so no extra config is needed.
    location / {
        proxy_pass http://127.0.0.1:3030;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }

    # Server-Sent Events + audio stream MUST be unbuffered, or live status and
    # audio will stall. These paths are proxied by the Nuxt server to the backend.
    location /api/events {
        proxy_pass http://127.0.0.1:3030;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 1h;
    }
    location /api/audio/stream {
        proxy_pass http://127.0.0.1:3030;
        proxy_buffering off;
        proxy_read_timeout 1h;
    }

    # --- Option B: serve under a sub-path (e.g. /anytone/) -------------------
    # Set NUXT_APP_BASE_URL=/anytone/ in your .env so the app's asset/API paths
    # match, then proxy that prefix instead of "/":
    #   location /anytone/        { proxy_pass http://127.0.0.1:3030; ... }
    #   location /anytone/api/events       { proxy_buffering off; ... }
    #   location /anytone/api/audio/stream { proxy_buffering off; ... }
}
