# ---- Dependencies / build ----
node_modules/
*.tsbuildinfo
dist/
.data/

# ---- Local config & secrets (never publish) ----
# TURN/API credentials live ONLY in the systemd drop-in (~/.config/systemd/user/…/*.conf).
.env
.env.*
!.env.example
*.local
*.local.*
.claude/

# ---- Runtime artifacts (machine-local) ----
recordings/
runtime-config.json
direwolf.conf
runtime/
logs/
*.log

# ---- Protocol captures & personal data ----
# Wire captures / codeplug exports contain personal data (callsign, contacts,
# channel names). captures/wire.ndjson is the one deliberate exception: a
# frozen, reviewed replay fixture the test suite depends on.
captures/
!captures/wire.ndjson
*.ndjson
!captures/wire.ndjson
*.CSV
*.csv
!examples/*.example.csv

# ---- Local-only research / RE workspaces ----
experiments/
firmware/

# ---- Editor / OS ----
.DS_Store
*.swp

# ---- Local-only RE tools (unpublished; the two whitelisted ones are repo tooling) ----
tools/*
!tools/gen-frame-lengths.mjs
!tools/fakephone.mjs
__pycache__/
*.pyc
