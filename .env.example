# AnyTone AT-D578UV controller — example environment configuration.
#
# Copy to `.env` (gitignored) and edit. The app reads plain environment
# variables — there is no separate config file format. Only ANYTONE_BT_ADDR is
# effectively required; everything else has a sensible default. See
# docs/CONFIGURATION.md for full descriptions.

# ─── Bluetooth radio identity (optional) ────────────────────────────────────
# Your radio's Bluetooth Classic MAC. RECOMMENDED but no longer required: when
# unset (or the placeholder below), the app discovers the radio by BT name on
# Connect, pairs + trusts it automatically, and persists the adopted address to
# .data/bt-state.json. Set this to pin one specific radio.
ANYTONE_BT_ADDR=AA:BB:CC:DD:EE:FF
# Name pattern (regex) used for discovery when the MAC is unset/unreachable. The
# radio is additionally disambiguated by advertising both SPP and HFP-AG.
# ANYTONE_BT_NAME_PATTERN=ELET_AGHF
# Pairing PIN for the auto-accept agent (legacy fixed-PIN radios). Just-Works
# pairing ignores it.
# ANYTONE_BT_PIN=0000
# Where the adopted address is cached.
# ANYTONE_BT_STATE=/home/youruser/anytone/app/.data/bt-state.json

# ─── Backend (anytone-server.mjs) ──────────────────────────────────────────
ANYTONE_SERVER_PORT=3010
ANYTONE_SERVER_HOST=127.0.0.1
# Bluetooth transport (defaults match a typical BlueZ + BlueALSA Linux host).
# Pairing/connect now run over BlueZ D-Bus (no bluetoothctl), and the BlueALSA HFP
# PCM path is resolved dynamically (adapter index + address) — no hci0 hardcoding.
ANYTONE_SPP_CHANNEL=2
ANYTONE_RFCOMM_ID=10
# ANYTONE_RFCOMM_PATH=/dev/rfcomm10
ANYTONE_RFCOMM_BAUD=115200
# ANYTONE_BLUEALSA_PCM=/org/bluealsa/hci0/dev_AA_BB_CC_DD_EE_FF/hfphf/source
ANYTONE_BLUEALSA_KEEPALIVE=30
ANYTONE_BLUEALSA_LOGLEVEL=warning
ANYTONE_BLUEALSA_CODEC=CVSD
ANYTONE_BLUEALSA_IO_RT_PRIORITY=20
ANYTONE_BLUEALSA_STOP_WIREPLUMBER=1
ANYTONE_KEEPALIVE_INTERVAL_MS=250
# Hard ceiling on a single PTT hold (ms), watchdog auto-release:
ANYTONE_PTT_MAX_MS=60000
# Relay passthrough (RE aid). When on, Connect opens the radio link but sends NO
# startup (WAKE/COM MODE/reads/COM CHECK END) and emits NO push-acks — a genuine
# BT-01 connected via /raw/ws drives COM MODE and acks the radio itself, so the
# wire log stays an uncontaminated head↔radio trace. Default off; connect can also
# pass { "relay": true } per session.
# ANYTONE_RELAY_MODE=0

# Command retransmit discipline (docs/RADIO_LINK_CONTRACT.md §7-§8). The radio drops
# ~3% of reads under load; we mirror the BT-01 and re-send retransmit-safe commands
# (idempotent reads + absolute writes) on a ~1s per-attempt timeout. Counters at
# GET /raw/metrics. Defaults shown; kill-switch ANYTONE_CMD_RETRANSMIT=0.
# ANYTONE_CMD_RETRANSMIT=1
# ANYTONE_CMD_TIMEOUT_MS=1000
# ANYTONE_CMD_ATTEMPTS=3
# Push-ACK latency budget: radio re-sends an un-acked push every ~500ms, so a slower
# ack causes a redundant re-send; breaches are counted at /raw/metrics.
# ANYTONE_ACK_BUDGET_MS=500

# Optional channel power/bandwidth enrichment from a CPS CSV export. The app runs
# fine without it (see examples/channels.example.csv for the schema).
# ANYTONE_CHANNELS_CSV=/path/to/your/channels.CSV

# Unsolicited-frame capture log (reverse-engineering aid). Default path is the
# gitignored captures/ dir. Set the FILE flag to 0 to disable file logging.
ANYTONE_ASYNC_LOG_FILE=1
# ANYTONE_ASYNC_LOG_PATH=./captures/unsolicited.ndjson
ANYTONE_ASYNC_LOG_LIMIT=300

# Full bidirectional wire log: every frame to (tx) and from (rx) the radio, in
# causal order, in one NDJSON file. On by default; set to 0 to disable, or point
# ANYTONE_WIRE_LOG_PATH elsewhere. Default path is the gitignored captures/ dir.
ANYTONE_WIRE_LOG_FILE=1
# ANYTONE_WIRE_LOG_PATH=./captures/wire.ndjson

# ─── UI (Nuxt server) ───────────────────────────────────────────────────────
PORT=3030
HOST=127.0.0.1
# Where the UI proxies API calls (the backend, above):
ANYTONE_SERVER_URL=http://127.0.0.1:3010
# UI mount path. Default "/" → open http://localhost:3030/ . Only set this if you
# serve the UI under a sub-path behind a reverse proxy (e.g. nginx at /anytone/).
# NUXT_APP_BASE_URL=/anytone/

# Recordings storage (squelch-triggered RX clips). Defaults to <cwd>/.data.
# CAT_DATA_PATH=./.data
# CAT_RECORDINGS_PATH=./.data/recordings
